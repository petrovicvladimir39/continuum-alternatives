{
  "name": "continuum-alternatives",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "typecheck": "pnpm -r run typecheck",
    "verify": "pnpm --filter @continuum/db verify && pnpm --filter @continuum/pipeline verify",
    "lint": "eslint .",
    "cli": "pnpm --filter @continuum/db cli",
    "format": "prettier --write .",
    "extract:benchmark": "pnpm --filter @continuum/pipeline extract:benchmark",
    "filings:backfill": "pnpm --filter @continuum/pipeline filings:backfill",
    "alsu:history": "pnpm --filter @continuum/pipeline alsu:history",
    "anomalies:scan": "pnpm --filter @continuum/pipeline anomalies:scan",
    "embeddings:backfill": "pnpm --filter @continuum/pipeline embeddings:backfill",
    "universe:import": "pnpm --filter @continuum/db universe:import",
    "universe:verify": "pnpm --filter @continuum/pipeline universe:verify",
    "geocode:backfill": "pnpm --filter @continuum/pipeline geocode:backfill",
    "logos:backfill": "pnpm --filter @continuum/pipeline logos:backfill",
    "enrich:batch": "pnpm --filter @continuum/pipeline enrich:batch",
    "gleif:harvest": "pnpm --filter @continuum/pipeline gleif:harvest",
    "registers:harvest": "pnpm --filter @continuum/pipeline registers:harvest",
    "ch:enrich": "pnpm --filter @continuum/pipeline ch:enrich",
    "wikidata:harvest": "pnpm --filter @continuum/pipeline wikidata:harvest",
    "sources:discover": "pnpm --filter @continuum/pipeline sources:discover",
    "portals:seed": "pnpm --filter @continuum/pipeline portals:seed",
    "export:entities": "pnpm --filter @continuum/pipeline export:entities",
    "export:edges": "pnpm --filter @continuum/pipeline export:edges",
    "export:facts": "pnpm --filter @continuum/pipeline export:facts",
    "export:documents": "pnpm --filter @continuum/pipeline export:documents",
    "extract:batch": "pnpm --filter @continuum/pipeline extract:batch",
    "articles:compose": "pnpm --filter @continuum/pipeline articles:compose",
    "contacts:send-confirmations": "pnpm --filter @continuum/pipeline contacts:send-confirmations",
    "classify:corpus": "pnpm --filter @continuum/pipeline classify:corpus",
    "alerts:backfill": "pnpm --filter @continuum/pipeline alerts:backfill",
    "events:import": "pnpm --filter @continuum/pipeline events:import",
    "events:harvest": "pnpm --filter @continuum/pipeline events:harvest"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  }
}

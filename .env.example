# Neon Postgres — pooled connection (runtime)
DATABASE_URL=
# Neon Postgres — direct/unpooled connection (migrations only)
DATABASE_URL_UNPOOLED=
# Anthropic API — extraction & synthesis
ANTHROPIC_API_KEY=
# Voyage AI — embeddings
VOYAGE_API_KEY=
# Firecrawl — web crawling
FIRECRAWL_API_KEY=
# Resend — transactional email & digests
RESEND_API_KEY=
# Companies House (GB) — free API key from developer.company-information.service.gov.uk
# Used by "pnpm ch:enrich" to stamp official status/incorporation/registered
# office onto existing GB organizations. The command degrades gracefully
# (clear message, no writes) when unset.
CH_API_KEY=
# Telegram bot — alerts & approvals
TELEGRAM_BOT_TOKEN=
# Telegram chat id for pipeline alerts
TELEGRAM_CHAT_ID=
# Clerk auth (Phase 24) — identity for /admin and /account. Without BOTH keys
# the public site runs untouched and /admin + /account answer 404.
# HTTP Basic Auth (ADMIN_USER/ADMIN_PASSWORD) was RETIRED in Phase 24.
# Sign-in methods (passkeys + email) are configured in the Clerk DASHBOARD,
# not in code. Admin access additionally requires the operator to set their
# user's publicMetadata.role = "admin" in the dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk webhook (user.created/user.deleted → member_profiles sync), svix-signed
CLERK_WEBHOOK_SECRET=
# Stripe (Phase 29) — founding memberships. Without SECRET_KEY +
# PRICE_FOUNDING every payment surface renders an honest "Memberships open
# soon" state (pre-config mode); nothing crashes. WEBHOOK_SECRET signs
# /api/webhooks/stripe (dashboard → Webhooks → signing secret; events:
# checkout.session.completed, customer.subscription.updated/deleted).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price id of the founding membership (price_..., recurring)
STRIPE_PRICE_FOUNDING=
# Founding seat cap — checkout closes at the cap (default 100)
FOUNDING_CAP=
# Vendor tier (Phase 33B) — recurring price for vendor profiles. Without it
# the steward surface says "Vendor profiles open soon."
STRIPE_PRICE_VENDOR=
# Stripe usage metering (Phase 33E) — OPTIONAL. When set, daily API usage
# reports as meter events (enterprise metered pricing is an operator
# decision later); unset = rollups stay log-only on /admin.
STRIPE_METER_EVENT_NAME=
# Langfuse — LLM observability (later phase)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=
# Upstash Redis — rate limiting (later phase)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Inngest — background jobs (later phase)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# News Desk weekly compose trigger — ships DISABLED; set to 1 to enable the
# scheduled Inngest function (composition still only creates proposed drafts)
ARTICLES_WEEKLY_ENABLED=
# Sentry — error tracking (Phase 23). All optional: without DSNs the SDK is
# a no-op; without SENTRY_AUTH_TOKEN no source maps upload at build.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Digest weekly autodraft (Phase 23D) — cron generates DRAFTS only when
# set to "true"; sending remains manual-approve forever.
DIGEST_AUTODRAFT=
# Plausible analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# OpenCorporates (clean-100 Part 6, optional) — registry-number/status
# enrichment for existing entities. Sign up at https://opencorporates.com/api_accounts/new
# (free tier available for public-benefit projects; attribution required on /about
# per their terms). Absent -> the OpenCorporates step is skipped.
OPENCORPORATES_API_KEY=
